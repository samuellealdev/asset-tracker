# ============================================
# Asset Tracker — Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- PostgreSQL (used by Go service) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=asset_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_SSLMODE=disable

# --- MongoDB (used by Node.js service) ---
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=asset_tracker
MONGO_USER=mongo
MONGO_PASSWORD=changeme
MONGO_AUTH_SOURCE=admin

# --- Connection Strings (used by services at runtime) ---
POSTGRES_DSN=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=${POSTGRES_SSLMODE}
MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=${MONGO_AUTH_SOURCE}
KAFKA_BROKER=localhost:9092

# --- Go Service ---
GO_SERVICE_PORT=8080
GO_PORT=8080
GO_SERVICE_LOG_LEVEL=debug

# --- Node.js Service ---
NODE_SERVICE_PORT=3000
NODE_PORT=3000
NODE_SERVICE_LOG_LEVEL=debug

# --- JWT / Auth ---
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRATION=1h

# --- Docker Registry ---
DOCKER_REGISTRY=localhost:5000
IMAGE_TAG=latest
